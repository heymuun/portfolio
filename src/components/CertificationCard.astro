---
import type { Certification } from "@/data/certifications";
import LinkButton from "./LinkButton.astro";

type Props = Certification;

const { title, issuer, issueDate, credentialUrl } = Astro.props;
---

<li class="my-6">
  {
    credentialUrl ? (
      <a
        href={credentialUrl}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          "text-accent inline-block text-lg font-medium",
          "decoration-dashed underline-offset-4 hover:underline",
          "focus-visible:no-underline focus-visible:underline-offset-0",
        ]}
      >
        <h3>{title}</h3>
      </a>
    ) : (
      <h3 class="text-lg font-medium">{title}</h3>
    )
  }

  <p class="text-muted-foreground mt-1 text-sm">{issuer}</p>

  <p class="text-muted-foreground mt-1 text-xs">{issueDate}</p>

  {
    credentialUrl && (
      <div class="mt-3">
        <LinkButton
          href={credentialUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent text-sm hover:underline"
        >
          View Credential
        </LinkButton>
      </div>
    )
  }
</li>
